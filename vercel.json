{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)\\.(css|js|svg|jpg|jpeg|png|webp)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=604800, immutable" }
      ]
    },
    {
      "source": "/(.*)\\.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ],
  "redirects": [
    { "source": "/ponte", "destination": "/ui_kits/ponte/index.html", "permanent": false },
    { "source": "/telas", "destination": "/canvas/todas-as-telas.html", "permanent": false }
  ],
  "rewrites": [
    { "source": "/ui_kits/ponte", "destination": "/ui_kits/ponte/index.html" },
    { "source": "/ui_kits/ponte/", "destination": "/ui_kits/ponte/index.html" }
  ]
}
